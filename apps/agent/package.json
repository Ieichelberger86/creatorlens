{
  "name": "@creatorlens/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t creatorlens-agent .",
    "docker:run": "docker run --rm -p 3100:3000 --env-file .env creatorlens-agent"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@creatorlens/db": "workspace:*",
    "@creatorlens/shared": "workspace:*",
    "better-sqlite3": "^11.3.0",
    "express": "^4.21.1",
    "pino": "^9.5.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
